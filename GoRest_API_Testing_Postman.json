    {
      "name": "CRUD Operations",
      "item": [
        {
          "name": "Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let response = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Status code is 201\", function () {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"User ID exists\", function () {\r",
                  "    pm.expect(response.id).to.exist;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Email contains @\", function () {\r",
                  "    pm.expect(response.email).to.include(\"@\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"User status is active\", function () {\r",
                  "    pm.expect(response.status).to.eql(\"active\");\r",
                  "});\r",
                  "\r",
                  "// SAVE for chaining\r",
                  "pm.environment.set(\"user_id\", response.id);\r",
                  "\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer 4fa0b85519983a803ce3337aed67e2b908c65158dccc2a5a497e4cd6a7568d75",
                "type": "text"
              },
              {
                "key": "Content-Type",
